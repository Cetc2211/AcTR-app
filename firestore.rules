
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isUserAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // This rule allows a user to read and write only their own documents.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow shared access to absences for monitoring
    match /absences/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow access to app configuration (roles, permissions) - only admins can write
    match /app_config/{document=**} {
      allow read: if request.auth != null;
      allow write: if isUserAdmin();
    }

    // Allow access to tracking logs (Bitácora)
    match /tracking_logs/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Allow access to official groups and centralized students
    match /official_groups/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /students/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Allow access to announcements
    match /announcements/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Allow access to justifications
    match /justifications/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Allow public access to observations and academic compliance for tutors/monitoring
    match /observations/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /academic_compliance/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Secure admin collection - allow initial setup, then restrict to admins
    match /admins/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth == null && email == 'mpceciliotopetecruz@gmail.com' ||
                   isUserAdmin() ||
                   (request.auth != null && request.auth.token.email == 'mpceciliotopetecruz@gmail.com');
    }
  }
}
